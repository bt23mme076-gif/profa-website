rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'vishallko31@gmail.com';
    }
    
    match /content/{document=**} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }
    
    match /newsletter_subscribers/{subscriberId} {
      // Allow anyone (even unauthenticated) to create if email is present and non-empty
      allow create: if request.resource.data.email is string &&
                      request.resource.data.email.size() > 0 &&
                      (request.auth == null || request.auth != null);
      allow read, update, delete: if isAdmin();
    }
    
    match /blogs/{postId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    match /blog_posts/{postId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    match /testimonials/{docId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    match /training_logos/{docId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    match /training_partners/{docId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }
    
    match /courses/{courseId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    match /researchCourses/{courseId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }
    
    match /books/{bookId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }
    
    match /contact_submissions/{submissionId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /trainings/{docId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    match /research/{docId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
